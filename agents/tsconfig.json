{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "shared/**/*.ts",
    "api/**/*.ts",
    "content/**/*.ts",
    "humanizer/**/*.ts",
    "qa/**/*.ts",
    "assembler/**/*.ts",
    "deploy/**/*.ts",
    "fail-handler/**/*.ts",
    "pipeline-starter/**/*.ts",
    "research/**/*.ts",
    "style/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
