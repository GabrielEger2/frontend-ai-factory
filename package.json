{
  "name": "sitegen",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "components",
    "dashboard",
    "agents",
    "infra"
  ],
  "scripts": {
    "synth": "cd infra && npx cdk synth --all",
    "deploy": "cd infra && npx cdk deploy --all",
    "db:seed": "npm run seed:components --workspace=agents",
    "components:storybook": "npm run storybook --workspace=components",
    "predeploy": "npm run generate-sources --workspace=agents",
    "components:type-check": "npm run type-check --workspace=components"
  }
}
