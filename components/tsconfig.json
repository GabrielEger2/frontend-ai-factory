{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@components/*": ["./library/*"],
      "@ui/*": ["./ui/*"],
      "@lib/*": ["./lib/*"],
      "@hooks/*": ["./hooks/*"]
    }
  },
  "include": [
    "*.ts",
    "library/**/*.ts",
    "library/**/*.tsx",
    "ui/**/*.ts",
    "ui/**/*.tsx",
    "@ui/**/*.ts",
    "@ui/**/*.tsx",
    "lib/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
