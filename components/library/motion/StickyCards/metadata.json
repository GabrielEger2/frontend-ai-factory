{
  "id": "layout-stickycards-01",
  "name": "Sticky Cards",
  "category": "motion",
  "style": [
    "modern",
    "bold",
    "editorial"
  ],
  "mood": [
    "professional",
    "energetic",
    "trustworthy"
  ],
  "layout": "stacked",
  "density": "low",
  "imageWeight": 0.08,
  "purpose": [
    "features",
    "services",
    "process"
  ],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": false,
    "button": false
  },
  "slots": [
    {
      "name": "headline",
      "type": "text",
      "maxLength": 80,
      "optional": true
    },
    {
      "name": "subheadline",
      "type": "text",
      "maxLength": 200,
      "optional": true
    },
    {
      "name": "cards",
      "type": "list",
      "maxItems": 6,
      "itemSchema": {
        "type": "object",
        "fields": [
          {
            "name": "content",
            "type": "component",
            "description": "Card body. Composer nests another component here (e.g. ImageText, CardGrid, IconListSplit) — content is not a text/image slot."
          }
        ]
      }
    },
    {
      "name": "cardHeight",
      "type": "number",
      "optional": true
    }
  ],
  "mobileBehavior": "scroll",
  "pairsWell": [
    "hero-geometric-01",
    "hero-split-image-01"
  ],
  "pairsPoorly": [
    "layout-cardgrid-01"
  ],
  "description": "A dynamic card layout that remains fixed during scroll to showcase key features or services with bold typography and editorial-style presentation. Perfect for professional service firms and agencies that need to communicate their process or capabilities with energy and authority."
}
