{
  "id": "navbar-sticky-01",
  "name": "Sticky Navbar",
  "category": "navigation",
  "purpose": [
    "navigation"
  ],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": false,
    "button": true
  },
  "style": [
    "modern",
    "minimal",
    "corporate"
  ],
  "mood": [
    "professional",
    "trustworthy",
    "friendly"
  ],
  "layout": "horizontal",
  "density": "low",
  "imageWeight": 0,
  "slots": [
    {
      "name": "logo",
      "type": "image",
      "aspectRatio": "auto",
      "optional": true
    },
    {
      "name": "links",
      "type": "list",
      "maxItems": 6,
      "itemSchema": {
        "text": {
          "type": "text",
          "maxLength": 30
        },
        "href": {
          "type": "url"
        }
      }
    },
    {
      "name": "ctaText",
      "type": "text",
      "maxLength": 20
    },
    {
      "name": "ctaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "ctaStyle",
      "type": "text",
      "optional": true,
      "enum": [
        "default",
        "slide",
        "dotExpand",
        "drawOutline"
      ]
    }
  ],
  "mobileBehavior": "collapse",
  "pairsWell": [],
  "pairsPoorly": [],
  "description": "A fixed navigation bar that remains visible while scrolling, featuring clean typography and subtle styling perfect for corporate websites and professional services that need consistent access to key menu items."
}
