{
  "id": "footer-pulse-01",
  "name": "Pulse Editorial Footer",
  "category": "footer",
  "purpose": ["footer"],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": false,
    "button": true
  },
  "style": ["modern", "editorial", "minimal"],
  "mood": ["professional", "elegant", "trustworthy"],
  "layout": "multi-column",
  "density": "medium",
  "imageWeight": 0.05,
  "slots": [
    {
      "name": "logo",
      "type": "image",
      "aspectRatio": "auto",
      "optional": true
    },
    {
      "name": "tagline",
      "type": "text",
      "maxLength": 120,
      "optional": true
    },
    {
      "name": "whatsappUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "whatsappText",
      "type": "text",
      "maxLength": 30
    },
    {
      "name": "phoneUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "phoneText",
      "type": "text",
      "maxLength": 30
    },
    {
      "name": "emailUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "emailText",
      "type": "text",
      "maxLength": 60
    },
    {
      "name": "addressText",
      "type": "text",
      "maxLength": 120
    },
    {
      "name": "addressMapsUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "hoursText",
      "type": "text",
      "maxLength": 60,
      "optional": true
    },
    {
      "name": "navColumns",
      "type": "list",
      "maxItems": 4,
      "itemSchema": {
        "title": {
          "type": "text",
          "maxLength": 30
        },
        "links": {
          "type": "list",
          "maxItems": 6,
          "itemSchema": {
            "text": {
              "type": "text",
              "maxLength": 30
            },
            "href": {
              "type": "url"
            }
          }
        }
      }
    },
    {
      "name": "socialLinks",
      "type": "list",
      "maxItems": 6,
      "itemSchema": {
        "network": {
          "type": "text",
          "maxLength": 20,
          "enum": [
            "instagram",
            "linkedin",
            "facebook",
            "whatsapp",
            "twitter",
            "youtube",
            "tiktok",
            "google",
            "pinterest",
            "telegram"
          ]
        },
        "url": {
          "type": "url"
        },
        "label": {
          "type": "text",
          "maxLength": 60
        }
      }
    },
    {
      "name": "companyName",
      "type": "text",
      "maxLength": 60
    },
    {
      "name": "ctaText",
      "type": "text",
      "maxLength": 40,
      "optional": true
    },
    {
      "name": "ctaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "ctaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow"]
    },
    {
      "name": "locationLabel",
      "type": "text",
      "maxLength": 30,
      "optional": true
    },
    {
      "name": "timezone",
      "type": "text",
      "maxLength": 60,
      "optional": true
    }
  ],
  "mobileBehavior": "stack",
  "pairsWell": ["faq-accordion-01", "navbar-pill-01"],
  "pairsPoorly": [
    "footer-columns-social-01",
    "footer-mega-01",
    "footer-minimal-strip-01",
    "footer-reveal-01"
  ],
  "description": "A clean, magazine-style footer with refined typography and minimal visual elements that builds credibility for editorial websites, publishing platforms, and content-focused businesses requiring professional authority.",
  "descriptions": {
    "descriptive": "A streamlined footer with generous whitespace and typography-forward design. Features clean sans-serif text hierarchy, subtle dividing lines, and restrained color palette. The editorial influence shows in careful text spacing and journalistic information architecture that feels both sophisticated and uncluttered.",
    "usage": "Anchors content-heavy websites where credibility and readability matter most. Perfect for publications, blogs, news sites, and professional services that need to maintain reader trust while providing essential navigation and contact information without visual distraction from the main content.",
    "audienceFit": "Appeals to established media companies, professional publications, consulting firms, and knowledge-based businesses. Resonates with educated audiences who value substance over flashiness, making it ideal for brands positioning themselves as thought leaders or authoritative information sources."
  }
}
