{
  "id": "hero-newsroom-ticker-01",
  "name": "Newsroom Ticker Hero",
  "category": "hero",
  "purpose": ["hero", "magazine-opener", "brand-statement", "story"],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": true,
    "button": true
  },
  "style": ["editorial", "classic", "modern"],
  "mood": ["serious", "trustworthy", "professional"],
  "layout": "asymmetric",
  "density": "high",
  "imageWeight": 0.2,
  "slots": [
    {
      "name": "tickerItems",
      "type": "list",
      "maxItems": 8,
      "itemSchema": {
        "type": "object",
        "fields": [
          { "name": "label", "type": "text", "maxLength": 16 },
          { "name": "value", "type": "text", "maxLength": 16 },
          {
            "name": "trend",
            "type": "text",
            "optional": true,
            "enum": ["up", "down", "flat"]
          }
        ]
      }
    },
    {
      "name": "issueLabel",
      "type": "text",
      "optional": true,
      "maxLength": 60
    },
    {
      "name": "headline",
      "type": "text",
      "maxLength": 140
    },
    {
      "name": "lede",
      "type": "text",
      "maxLength": 320
    },
    {
      "name": "ctaText",
      "type": "text",
      "maxLength": 30
    },
    {
      "name": "ctaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "ctaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow", "arrow"]
    },
    {
      "name": "ctaColorScheme",
      "type": "text",
      "optional": true,
      "enum": ["primary", "secondary", "accent", "neutral"]
    },
    {
      "name": "secondaryCtaText",
      "type": "text",
      "optional": true,
      "maxLength": 30
    },
    {
      "name": "secondaryCtaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "secondaryCtaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow", "arrow"]
    },
    {
      "name": "secondaryCtaColorScheme",
      "type": "text",
      "optional": true,
      "enum": ["primary", "secondary", "accent", "neutral"]
    },
    {
      "name": "featuredHeadlines",
      "type": "list",
      "optional": true,
      "maxItems": 4,
      "itemSchema": {
        "type": "object",
        "fields": [
          { "name": "kicker", "type": "text", "maxLength": 30 },
          { "name": "title", "type": "text", "maxLength": 140 },
          { "name": "url", "type": "url", "optional": true },
          {
            "name": "meta",
            "type": "text",
            "optional": true,
            "maxLength": 40
          },
          {
            "name": "image",
            "type": "image",
            "optional": true,
            "aspectRatio": "4:3"
          },
          {
            "name": "imageAlt",
            "type": "text",
            "optional": true,
            "maxLength": 80
          }
        ]
      }
    },
    {
      "name": "featuredHeadlinesLabel",
      "type": "text",
      "optional": true,
      "maxLength": 40
    }
  ],
  "mobileBehavior": "stack",
  "pairsWell": ["stats-count-up-01"],
  "pairsPoorly": [
    "hero-split-image-01",
    "hero-bakery-editorial-01",
    "hero-grid-gallery-01",
    "hero-video-backdrop-01",
    "hero-split-form-01",
    "hero-asymmetric-stack-01",
    "hero-polaroid-collage-01"
  ],
  "description": "An editorial-newsroom hero with a live data ticker, oversized serif headline, lede paragraph, and a side rail of featured stories. Built for publications, financial-data products, research firms, and any brand that wants to read like a front page.",
  "descriptions": {
    "descriptive": "A monospace ticker scrolls along the top edge with up/down sentiment glyphs and trend tints. Below, an issue rule frames a serif display headline and a horizontal divider tucks the lede beneath the title. The right rail stacks featured stories with kickers, optional thumbnails, and meta lines that read like a print contents page.",
    "usage": "Best for media properties, research firms, fintech and B2B SaaS data products, and any homepage where credibility comes from showing live information at the top. The side rail can be repurposed for case studies, latest releases, or featured projects.",
    "audienceFit": "Reads as authoritative to professional readers — investors, analysts, journalists, policy folk, and B2B buyers — who associate density and serif typography with trustworthy reporting."
  }
}
