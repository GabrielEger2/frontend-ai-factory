{
  "id": "hero-spotlight-center-01",
  "name": "Spotlight Center Hero",
  "category": "hero",
  "purpose": ["hero", "brand-statement", "lead-capture"],
  "acceptsStyleKit": {
    "card": false,
    "background": true,
    "textDecoration": true,
    "button": true
  },
  "style": ["minimal", "modern", "luxury"],
  "mood": ["elegant", "calm", "trustworthy"],
  "layout": "centered",
  "density": "low",
  "imageWeight": 0.3,
  "slots": [
    {
      "name": "eyebrow",
      "type": "text",
      "optional": true,
      "maxLength": 60
    },
    {
      "name": "headline",
      "type": "text",
      "maxLength": 120
    },
    {
      "name": "subheadline",
      "type": "text",
      "optional": true,
      "maxLength": 220
    },
    {
      "name": "ctaText",
      "type": "text",
      "maxLength": 30
    },
    {
      "name": "ctaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "ctaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow", "arrow"]
    },
    {
      "name": "ctaColorScheme",
      "type": "text",
      "optional": true,
      "enum": ["primary", "secondary", "accent", "neutral"]
    },
    {
      "name": "secondaryCtaText",
      "type": "text",
      "optional": true,
      "maxLength": 30
    },
    {
      "name": "secondaryCtaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "secondaryCtaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow", "arrow"]
    },
    {
      "name": "secondaryCtaColorScheme",
      "type": "text",
      "optional": true,
      "enum": ["primary", "secondary", "accent", "neutral"]
    },
    {
      "name": "spotlightImage",
      "type": "image",
      "optional": true,
      "aspectRatio": "1:1"
    },
    {
      "name": "spotlightImageAlt",
      "type": "text",
      "optional": true,
      "maxLength": 120
    },
    {
      "name": "chips",
      "type": "list",
      "optional": true,
      "maxItems": 4,
      "itemSchema": {
        "type": "object",
        "fields": [
          { "name": "label", "type": "text", "maxLength": 30 },
          {
            "name": "position",
            "type": "text",
            "optional": true,
            "enum": ["top-left", "top-right", "bottom-left", "bottom-right"]
          },
          {
            "name": "image",
            "type": "image",
            "optional": true,
            "aspectRatio": "1:1"
          },
          {
            "name": "imageAlt",
            "type": "text",
            "optional": true,
            "maxLength": 80
          }
        ]
      }
    },
    {
      "name": "showRadialGlow",
      "type": "boolean",
      "optional": true
    }
  ],
  "mobileBehavior": "stack",
  "pairsWell": [
    "layout-cardgrid-01",
    "stats-count-up-01",
    "layout-imagetext-01",
    "layout-iconlistsplit-01"
  ],
  "pairsPoorly": [
    "hero-split-image-01",
    "hero-geometric-01",
    "hero-shuffle-cards-01",
    "hero-parallax-images-01",
    "hero-hero-bold-editorial-01",
    "hero-bakery-editorial-01",
    "hero-marquee-strip-01",
    "hero-grid-gallery-01",
    "hero-video-backdrop-01",
    "hero-newsroom-ticker-01",
    "hero-split-form-01",
    "hero-asymmetric-stack-01",
    "hero-terminal-console-01",
    "hero-polaroid-collage-01"
  ],
  "description": "A calm, centered hero with a soft radial accent glow, optional portrait spotlight, and floating contextual chips that orbit the headline. Designed for boutique brands, premium SaaS, and creator-led pages where restraint signals quality.",
  "descriptions": {
    "descriptive": "An eyebrow pill, a balanced display headline, and a pair of CTAs sit centered over a single low-saturation radial halo. Optional small chips with avatars float at the corners to suggest context — pricing, availability, social proof — without crowding the headline. A semi-transparent portrait sits behind the type for visual depth.",
    "usage": "Best for boutique services, creators, premium SaaS waitlists, and announcement pages where the message is short and the brand benefits from negative space. Pair with a stats strip or icon list below to layer in detail without disturbing the calm.",
    "audienceFit": "Resonates with audiences who associate restraint with quality — boutique hospitality, premium consumer products, founder-led services, and high-trust B2B."
  }
}
