    {
      "name": "secondaryCtaText",
      "type": "text",
      "optional": true,
      "maxLength": 30
    },
    { "name": "secondaryCtaUrl", "type": "url", "optional": true },
    {
      "name": "secondaryCtaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow"]
    },
    {
      "name": "secondaryCtaColorScheme",
      "type": "text",
