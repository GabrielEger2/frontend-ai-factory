  "category": "hero",
  "purpose": ["hero"],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": true,
    "button": true
  },
  "style": ["modern", "editorial", "bold"],
  "mood": ["energetic", "elegant", "professional"],
  "layout": "centered",
  "density": "high",
  "imageWeight": 0.15,
  "slots": [
