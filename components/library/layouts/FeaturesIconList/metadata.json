{
  "id": "features-icon-list-01",
  "name": "Icon List with Image",
  "category": "layouts",
  "style": ["modern", "corporate"],
  "mood": ["professional", "trustworthy", "friendly"],
  "layout": "split",
  "density": "medium",
  "slots": [
    { "name": "headline", "type": "text", "maxLength": 80 },
    {
      "name": "features",
      "type": "list",
      "maxItems": 5,
      "itemSchema": {
        "icon": { "type": "text", "maxLength": 10 },
        "title": { "type": "text", "maxLength": 60 },
        "description": { "type": "text", "maxLength": 200 }
      }
    },
    {
      "name": "image",
      "type": "image",
      "optional": true,
      "aspectRatio": "1:1"
    },
    { "name": "imageAlt", "type": "text", "optional": true, "maxLength": 120 },
    {
      "name": "logos",
      "type": "list",
      "optional": true,
      "maxItems": 8,
      "itemSchema": {
        "image": { "type": "image" },
        "imageAlt": { "type": "text", "maxLength": 60 }
      }
    }
  ],
  "mobileBehavior": "stack",
  "pairsWell": [
    "hero-split-image-01",
    "testimonial-showcase-01",
    "cta-banner-01",
    "content-author-split-01"
  ],
  "pairsPoorly": ["features-cards-01"]
}
