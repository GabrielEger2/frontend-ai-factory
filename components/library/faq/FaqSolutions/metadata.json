{
  "id": "faq-solutions-01",
  "name": "FAQ Solutions",
  "category": "faq",
  "purpose": ["faq"],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": false,
    "button": true
  },
  "style": ["modern", "bold"],
  "mood": ["professional", "energetic"],
  "layout": "split",
  "density": "medium",
  "slots": [
    { "name": "headline", "type": "text", "maxLength": 80 },
    { "name": "subheadline", "type": "text", "maxLength": 160 },
    {
      "name": "items",
      "type": "list",
      "maxItems": 5,
      "itemSchema": {
        "type": "object",
        "fields": [
          { "name": "title", "type": "text", "maxLength": 60 },
          { "name": "description", "type": "text", "maxLength": 300 },
          { "name": "ctaText", "type": "text", "maxLength": 30 },
          { "name": "ctaUrl", "type": "url" },
          { "name": "image", "type": "image", "aspectRatio": "4:3" },
          { "name": "imageAlt", "type": "text", "maxLength": 120 }
        ]
      }
    },
    { "name": "ctaStyle", "type": "text", "optional": true },
    { "name": "ctaColorScheme", "type": "text", "optional": true }
  ],
  "mobileBehavior": "stack",
  "pairsWell": ["hero-split-01", "cta-banner-01", "testimonials-carousel-01"],
  "pairsPoorly": ["faq-accordion-01", "faq-minimal-01"]
}
