{
  "id": "testimonials-scrolling-01",
  "name": "Scrolling Testimonials",
  "category": "testimonials",
  "style": ["modern", "bold"],
  "mood": ["energetic", "trustworthy"],
  "layout": "stacked",
  "density": "high",
  "slots": [
    { "name": "headline", "type": "text", "maxLength": 80 },
    {
      "name": "subheadline",
      "type": "text",
      "maxLength": 200,
      "optional": true
    },
    {
      "name": "rows",
      "type": "list",
      "maxItems": 3,
      "itemSchema": {
        "type": "list",
        "maxItems": 8,
        "itemSchema": {
          "type": "object",
          "fields": [
            { "name": "image", "type": "image", "aspectRatio": "1:1" },
            { "name": "imageAlt", "type": "text", "maxLength": 120 },
            { "name": "name", "type": "text", "maxLength": 40 },
            { "name": "title", "type": "text", "maxLength": 60 },
            { "name": "quote", "type": "text", "maxLength": 200 }
          ]
        }
      }
    }
  ],
  "mobileBehavior": "scroll",
  "pairsWell": [
    "hero-geometric-01",
    "hero-split-01",
    "cta-banner-01",
    "features-cards-01"
  ],
  "pairsPoorly": ["testimonials-stacked-01", "testimonials-stagger-01"]
}
