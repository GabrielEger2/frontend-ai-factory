{
  "id": "features-sticky-cards-01",
  "name": "Sticky Cards Features",
  "category": "features",
  "style": ["modern", "bold", "editorial"],
  "mood": ["professional", "energetic", "trustworthy"],
  "layout": "stacked",
  "density": "low",
  "slots": [
    {
      "name": "headline",
      "type": "text",
      "optional": true,
      "maxLength": 80
    },
    {
      "name": "subheadline",
      "type": "text",
      "optional": true,
      "maxLength": 200
    },
    {
      "name": "cards",
      "type": "list",
      "maxItems": 6,
      "itemSchema": {
        "type": "object",
        "fields": [
          { "name": "icon", "type": "text", "optional": true, "maxLength": 10 },
          {
            "name": "image",
            "type": "image",
            "optional": true,
            "aspectRatio": "4:3"
          },
          {
            "name": "imageAlt",
            "type": "text",
            "optional": true,
            "maxLength": 120
          },
          { "name": "title", "type": "text", "maxLength": 60 },
          { "name": "description", "type": "text", "maxLength": 200 },
          { "name": "ctaText", "type": "text", "maxLength": 30 },
          { "name": "ctaUrl", "type": "url" }
        ]
      }
    },
    {
      "name": "ctaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow"]
    },
    {
      "name": "ctaColorScheme",
      "type": "text",
      "optional": true,
      "enum": ["primary", "secondary", "accent", "neutral"]
    }
  ],
  "mobileBehavior": "scroll",
  "pairsWell": ["hero-geometric-01", "hero-split-image-01", "cta-banner-01"],
  "pairsPoorly": ["features-grid-01"]
}
