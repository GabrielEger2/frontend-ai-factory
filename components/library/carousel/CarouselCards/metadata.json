{
  "id": "carousel-cards-01",
  "name": "Card Carousel",
  "category": "carousel",
  "style": ["modern", "corporate"],
  "mood": ["professional", "trustworthy"],
  "layout": "stacked",
  "density": "medium",
  "slots": [
    { "name": "headline", "type": "text", "maxLength": 60 },
    {
      "name": "cards",
      "type": "list",
      "maxItems": 12,
      "itemSchema": {
        "type": "object",
        "fields": [
          { "name": "image", "type": "image", "aspectRatio": "16:9" },
          { "name": "imageAlt", "type": "text", "maxLength": 120 },
          { "name": "tag", "type": "text", "maxLength": 30 },
          { "name": "title", "type": "text", "maxLength": 80 },
          { "name": "description", "type": "text", "maxLength": 160 }
        ]
      }
    }
  ],
  "mobileBehavior": "scroll",
  "pairsWell": ["hero-split-01", "testimonials-scrolling-01", "cta-banner-01"],
  "pairsPoorly": ["carousel-swipe-01", "carousel-3d-01"]
}
