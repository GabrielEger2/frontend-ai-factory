{
  "id": "products-category-grid-01",
  "name": "Products Category Grid",
  "category": "products",
  "style": ["editorial", "modern", "bold", "minimal"],
  "mood": ["elegant", "friendly", "trustworthy", "professional"],
  "purpose": ["products", "showcase", "gallery"],
  "acceptsStyleKit": {
    "card": false,
    "background": true,
    "textDecoration": false,
    "button": true
  },
  "layout": "grid",
  "density": "medium",
  "imageWeight": 0.6,
  "slots": [
    {
      "name": "eyebrow",
      "type": "text",
      "optional": true,
      "maxLength": 30
    },
    {
      "name": "headline",
      "type": "text",
      "maxLength": 80
    },
    {
      "name": "subheadline",
      "type": "text",
      "optional": true,
      "maxLength": 160
    },
    {
      "name": "categories",
      "type": "list",
      "minItems": 4,
      "maxItems": 8,
      "itemSchema": {
        "name": { "type": "text", "maxLength": 40 },
        "image": { "type": "image", "aspectRatio": "4:5" },
        "imageAlt": { "type": "text", "maxLength": 160 },
        "itemCount": { "type": "text", "optional": true, "maxLength": 30 },
        "priceFrom": { "type": "text", "optional": true, "maxLength": 40 },
        "ctaUrl": { "type": "url" }
      }
    },
    {
      "name": "ctaText",
      "type": "text",
      "optional": true,
      "maxLength": 30
    },
    {
      "name": "ctaUrl",
      "type": "url",
      "optional": true
    },
    {
      "name": "ctaStyle",
      "type": "text",
      "optional": true,
      "enum": ["default", "slide", "dotExpand", "drawOutline", "glow", "arrow"]
    },
    {
      "name": "ctaColorScheme",
      "type": "text",
      "optional": true,
      "enum": ["primary", "secondary", "accent", "neutral"]
    },
    {
      "name": "tone",
      "type": "text",
      "optional": true,
      "enum": ["light", "dark"]
    }
  ],
  "mobileBehavior": "stack",
  "pairsWell": [
    "hero-bakery-editorial-01",
    "hero-grid-gallery-01",
    "hero-split-image-01",
    "footer-columns-social-01",
    "footer-mega-01",
    "cta-hover-reveal-list-01",
    "cta-sticky-image-list-01"
  ],
  "pairsPoorly": [
    "pricing-tier-cards-01",
    "pricing-monthly-annual-toggle-01",
    "gallery-masonry-01",
    "gallery-lightbox-grid-01"
  ]
}
