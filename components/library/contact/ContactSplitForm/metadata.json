{
  "id": "contact-split-form-01",
  "name": "Split Contact Form",
  "category": "contact",
  "purpose": ["contact", "lead-capture", "location-display"],
  "acceptsStyleKit": {
    "card": false,
    "background": false,
    "textDecoration": false,
    "button": true
  },
  "style": ["modern", "minimal", "corporate"],
  "mood": ["professional", "calm", "trustworthy"],
  "layout": "split",
  "density": "medium",
  "imageWeight": 0,
  "slots": [
