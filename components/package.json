    "@storybook/react-webpack5": "^8.1",
    "@types/node": "^20",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "autoprefixer": "^10.4",
    "next": "^15",
    "postcss": "^8.4",
    "postcss-loader": "^8.2",
    "react": "^18.3",
    "react-dom": "^18.3",
    "storybook": "^8.1",
    "tailwindcss": "^3.4",
